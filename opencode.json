{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dewey": {
      "type": "local",
      "command": [
        "dewey",
        "serve",
        "--backend",
        "obsidian",
        "--vault",
        "."
      ],
      "enabled": true
    },
    "replicator": {
      "type": "local",
      "command": [
        "replicator",
        "serve"
      ],
      "enabled": true
    }
  }
}
